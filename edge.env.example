# RIST Edge 서버 비밀/환경 값 (git 추적 대상 아님)
#
# 이 파일은 deploy/install.sh 가 프로젝트 루트의 edge.env 로 복사한다(이미 있으면 보존).
#   경로: /home/rist/ritas/edge.env  (.gitignore 에 등록되어 git 추적 안 됨)
# 실제 운영 값으로 edge.env 를 직접 수정한 뒤 서비스를 재시작한다.
# 서비스 파일(rist-edge-*.service)에는 비밀값을 넣지 않으므로 git pull 충돌이 없다.
#
# 적용:
#   sudo systemctl restart rist-edge-api.service rist-edge-worker.service

# --- MariaDB 접속 정보 ---
RIST_DB_HOST=127.0.0.1
RIST_DB_PORT=3306
RIST_DB_NAME=rist_edge
RIST_DB_USER=rist
RIST_DB_PASSWORD=change-me

# --- 필요 시 로깅/기타 재정의 ---
# RIST_LOG_LEVEL=INFO
# RIST_LOG_FORMAT=text

# --- FT-IR 피크 assignment 라이브러리 ---
# 기본값: /home/rist/ritas/edge_api_server/data/ftir_assignment_libraries
# RIST_FTIR_ASSIGNMENT_LIBRARY_DIR=/data/rist/ftir_assignment_libraries
# 기본값: false. true로 바꾸면 /ftir 화면과 API에서 라이브러리 파일 삭제 허용
# RIST_FTIR_ASSIGNMENT_LIBRARY_DELETE_ENABLED=false
