# Development profile
APP_ENV=development

# Edge API exposed to experiment PCs on the development LAN
EDGE_SERVER_SCHEME=http
EDGE_SERVER_HOST=192.168.0.10
EDGE_SERVER_PORT=8000
EDGE_SERVER_BASE_URL=http://192.168.0.10:8000

# Edge process bind address
EDGE_BIND_HOST=0.0.0.0

# Absolute path where uploaded job files are stored.
# Leave empty to use the default (<edge_api_server>/data/jobs).
EDGE_STORAGE_ROOT=

# Local OpenAI-compatible LLM
LOCAL_LLM_BASE_URL=http://127.0.0.1:8001
LOCAL_LLM_MODEL=gemma4-e4b
LOCAL_LLM_TEMPERATURE=0.1
LOCAL_LLM_MAX_TOKENS=1200
LOCAL_LLM_CONTEXT_WINDOW=8192
LOCAL_LLM_CONTEXT_MARGIN=256
LOCAL_LLM_VALIDATE_MODEL=true
LOCAL_LLM_INCLUDE_IMAGES=true
LOCAL_LLM_MAX_IMAGES=3
LOCAL_LLM_MAX_IMAGE_BYTES=2097152

# Shared public domain reference
PUBLIC_DOMAIN=bhyoon.me
