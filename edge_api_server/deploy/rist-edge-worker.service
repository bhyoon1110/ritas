[Unit]
Description=RIST Edge Report Worker (LLM report generator)
After=network-online.target rist-vllm.service rist-edge-api.service
Wants=network-online.target
# 로컬 LLM 이 준비되어야 보고서를 생성할 수 있으므로 vLLM 서비스와 함께 묶는다.
Requires=rist-vllm.service

[Service]
Type=simple
User=rist
Group=rist

WorkingDirectory=/home/rist/ritas/edge_api_server
Environment=RIST_ENV=production
# API 서비스와 동일한 환경/비밀값 파일을 공유한다(git 추적 밖).
EnvironmentFile=-/home/rist/ritas/edge.env
# 로깅: API 서비스와 동일 정책. worker 로그는 별도 파일로 분리한다.
Environment=RIST_LOG_LEVEL=INFO
Environment=RIST_LOG_FORMAT=text
Environment=RIST_LOG_FILE=/home/rist/ritas/edge_api_server/data/logs/worker.log
ExecStart=/home/rist/ritas/.venv/bin/python -m app.report_worker

Restart=always
RestartSec=5

# 보안 강화
NoNewPrivileges=true
ProtectSystem=full
PrivateTmp=true

[Install]
WantedBy=multi-user.target
